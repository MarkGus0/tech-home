---
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import RedirectPage from "@components/RedirectPage.astro";
import { goLinks, type GoSlug } from "@data/forms";
import "@styles/global.css";

export function getStaticPaths() {
  return Object.keys(goLinks).map((slug) => ({ params: { slug } }));
}

const slug = Astro.params.slug as GoSlug;
const pageTitleEn = "External link confirmation";
const enableVercelInsights = import.meta.env.PUBLIC_ENABLE_VERCEL_INSIGHTS === "true";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{pageTitleEn} — TechFlows</title>
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
  </head>
  <body class="redirect-body" data-locale="en" data-page="redirect">
    <RedirectPage slug={slug} locale="en" />
    {enableVercelInsights && <Analytics />}
    {enableVercelInsights && <SpeedInsights />}
  </body>
</html>
