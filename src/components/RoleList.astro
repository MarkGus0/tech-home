---
import type { Localized } from "@data/translations";
import type { Locale } from "@data/site";

type Props = {
  items: Array<{ title: Localized<string>; description: Localized<string> }>;
  locale: Locale;
};

const { items, locale } = Astro.props;
---
<div class="work-list">
  {items.map((item) => (
    <article class="work-item">
      <h3>{item.title[locale]}</h3>
      <p>{item.description[locale]}</p>
    </article>
  ))}
</div>
