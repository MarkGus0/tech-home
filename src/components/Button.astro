---
type Props = {
  href: string;
  variant?: "primary" | "secondary";
  external?: boolean;
};

const { href, variant = "primary", external = false } = Astro.props;
---
<a class={`button button-${variant}`} href={href} target={external ? "_blank" : undefined} rel={external ? "noopener noreferrer" : undefined}>
  <slot />
</a>
